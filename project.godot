; Engine configuration file.
; Razorfin .io — a 2D top-down physics brawler in the open ocean.
;
; Apex predators with built-in weapons: ram with the hammerhead, slash with the saw,
; joust with the swordfish bill, crack the stingray's venom tail. Damage is WHERE you
; touch — the weapon part wounds, the body only shoves. Steer with one finger, hold
; one button to boost. Eat what they spill, and grow.
;
; Open by pointing Godot 4.7+ at this folder. Everything is code-built placeholder art,
; so it runs straight from a clean checkout with no asset pipeline.

config_version=5

[application]

config/name="Razorfin .io"
config/description="A physics top-down .io brawler where apex sea predators ram, saw and sting. Grow by eating rivals."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/show_image=false

[autoload]

Game="*res://scripts/Game.gd"
Sfx="*res://scripts/Sfx.gd"
CrazySdk="*res://scripts/CrazySdk.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

[input_devices]

pointing/emulate_mouse_from_touch=false

[physics]

; A phone that dips below 60 fps must slow the sim slightly, not run extra catch-up
; physics ticks (the default 8 invites a death spiral: slow frame -> more ticks -> slower).
common/max_physics_steps_per_frame=4

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.02, 0.05, 0.12, 1)

[input]

